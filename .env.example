# ========== 环境配置 ==========
# 运行环境: development / production
APP_ENV=development
# 是否使用 Mock 数据（true=Mock, false=真实调用）
USE_MOCK=true

# ========== 后端配置 ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# JWT 密钥（生产环境务必修改）
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 跨域配置
CORS_ORIGINS=http://localhost:3000,http://localhost

# ========== 数据库配置 ==========
POSTGRES_USER=pdd
POSTGRES_PASSWORD=pdd_secret
POSTGRES_DB=precision_drug
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pdd:pdd_secret@postgres:5432/precision_drug

# ========== Redis ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== ChromaDB（向量检索） ==========
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ========== Neo4j（图数据库） ==========
NEO4J_HOST=neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# ========== MinIO（对象存储） ==========
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=pdd-data

# ========== Nextflow ==========
NEXTFLOW_WORK_DIR=/data/nextflow/work
NEXTFLOW_CONFIG=/app/nextflow/nextflow.config

# ========== 大模型 API ==========
# litellm/openai 配置（USE_MOCK=false 时生效）
OPENAI_API_KEY=
# LLM API Key 加密密钥（Fernet 对称加密，留空则明文存储 — 仅开发环境）
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=
# 模型选择
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_DEEP=gpt-4o
# 分级分析成本/时间阈值
FAST_SCREEN_MAX_COST_USD=5
FAST_SCREEN_MAX_DURATION_SEC=300
DEEP_INSIGHT_MAX_COST_USD=20
DEEP_INSIGHT_MAX_DURATION_SEC=1800

# ========== 外部生物医学 API ==========
MYGENE_BASE_URL=https://mygene.info/v3
MYVARIANT_BASE_URL=https://myvariant.info/v1
CHEMBL_BASE_URL=https://www.ebi.ac.uk/chembl/api/data
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# ========== DiffDock（NVIDIA NIM） ==========
NVIDIA_NIM_API_KEY=
DIFFDOCK_NIM_URL=https://integrate.api.nvidia.com/v1/genai/biology/mit/diffdock

# ========== 前端配置 ==========
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
