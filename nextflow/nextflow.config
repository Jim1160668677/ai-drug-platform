// Nextflow 配置 — AI精准药物设计系统
// 默认使用 docker profile，可切换 standard（本地执行）

manifest {
    name        = 'ai-drug-pipelines'
    version     = '0.1.0'
    description = 'AI精准药物设计系统 — 生信流程'
    author      = 'AI Drug Team'
}

profiles {
    standard {
        process.executor = 'local'
        process.cpus = 2
        process.memory = '4 GB'
        process.time = '2h'
    }

    docker {
        docker.enabled = true
        process.executor = 'local'
        process.container = 'python:3.11-slim'
        process.cpus = 2
        process.memory = '4 GB'
        process.time = '2h'
    }

    k8s {
        k8s {
            namespace = 'ai-drug'
            serviceAccount = 'nextflow'
            storageClaimName = 'nextflow-workdir'
        }
        process.executor = 'k8s'
    }
}

// 全局参数
params {
    output = "./results"
    container_registry = "docker.io"
}

// 时间戳格式
process {
    errorStrategy = 'retry'
    maxRetries = 2
}

// 时间戳输出
timeline {
    enabled = true
    file = "timeline.html"
}
